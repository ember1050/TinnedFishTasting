# Supabase connection (used by the app + CSP in next.config.ts)
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Testing workflow:
#   - Point .env.local at the STAGING project so local dev never touches prod.
#   - Production credentials live only in Vercel's environment variables.
#   - Apply DB migrations to staging first (supabase db push against the staging
#     project), verify, then apply to prod.
